NODE_ENV="development"
SERVER_ENV="development"
DATABASE_URL="postgresql://guildkit:guildkit@localhost:5432/guildkit"
# Base URL of the app
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="REPLACE_ME_ON_PRODUCTION"

STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_REGION="us-east-1" # use us-east-1 on local since it is min.io's default
# STORAGE_AVAILABILITY_ZONE=
STORAGE_BUCKET="guildkit"
STORAGE_ACCESS_KEY="guildkit" # Same as MINIO_ROOT_USER on min.io
STORAGE_SECRET_KEY="guildkit" # Same as MINIO_ROOT_PASSWORD on min.io

GOOGLE_CLIENT_ID="REPLACE_ME_ON_PRODUCTION"
GOOGLE_CLIENT_SECRET="REPLACE_ME_ON_PRODUCTION"
GITHUB_CLIENT_ID="REPLACE_ME_ON_PRODUCTION"
GITHUB_CLIENT_SECRET="REPLACE_ME_ON_PRODUCTION"

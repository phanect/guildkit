{
  "name": "guildkit",
  "version": "0.0.1-prealpha",
  "author": "Jumpei Ogawa (https://phanective.org)",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "scripts": {
    "dev": "pnpm run sync && pg_ctl restart && jiti ./scripts/build-db-seed.ts && vite dev; pg_ctl stop",
    "db": "pg_ctl restart && psql --username=guildkit --dbname=guildkit; pg_ctl stop",
    "dbsu": "pg_ctl restart && psql --username=postgres --dbname=postgres; pg_ctl stop",
    "build": "pnpm run sync && vite build",
    "lint": "pnpm run sync && svelte-check --tsconfig ./tsconfig.json && eslint && markuplint \"**/*.html\"",
    "fix": "pnpm run sync && eslint --fix",
    "clean": "git clean -dX --exclude=\"!.env\" --exclude=\"!*.db\" --force",
    "refresh": "pnpm run clean && rm --force ./pnpm-lock.yaml && corepack up && pnpm install",
    "sync": "pg_ctl restart && svelte-kit sync && prisma migrate dev; pg_ctl stop",
    "prepare": "bash ./scripts/prepare-pg.sh && pnpm run sync"
  },
  "dependencies": {
    "@prisma/client": "^6.3.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.14.1"
  },
  "devDependencies": {
    "@markuplint/ml-config": "^4.8.10",
    "@melt-ui/pp": "^0.3.2",
    "@melt-ui/svelte": "^0.86.2",
    "@phanect/configs": "latest",
    "@phanect/lint": "latest",
    "@phanect/lint-svelte": "latest",
    "@sveltejs/adapter-auto": "^4.0.0",
    "@sveltejs/kit": "^2.17.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/forms": "^0.5.3",
    "@tailwindcss/postcss": "^4.0.7",
    "@tailwindcss/vite": "^4.0.7",
    "@types/bcryptjs": "^2.4.2",
    "@types/jsonwebtoken": "^9.0.2",
    "dayjs": "^1.11.11",
    "deepmerge": "^4.3.1",
    "eslint": "^9.11.0",
    "jiti": "^2.4.2",
    "markuplint": "^4.11.8",
    "postcss": "^8.4.23",
    "postcss-load-config": "^6.0.1",
    "prisma": "^6.3.0",
    "sass": "^1.86.1",
    "svelte": "^5.19.7",
    "svelte-check": "^4.1.4",
    "svelte-preprocess": "^6.0.3",
    "sveltekit-superforms": "^2.23.1",
    "tailwindcss": "^4.0.7",
    "tslib": "^2.4.1",
    "typescript": "^5.0.0",
    "vite": "^6.0.11",
    "zod": "^3.21.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "es5-ext",
      "esbuild",
      "prisma",
      "svelte-preprocess"
    ]
  },
  "engines": {
    "node": "22.x",
    "pnpm": ">=10.x"
  },
  "packageManager": "pnpm@10.8.0+sha512.0e82714d1b5b43c74610193cb20734897c1d00de89d0e18420aebc5977fa13d780a9cb05734624e81ebd81cc876cd464794850641c48b9544326b5622ca29971"
}
